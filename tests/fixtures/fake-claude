#!/bin/bash
# tests/fixtures/fake-claude
#
# A stand-in for the real `claude` binary used by the end-to-end test suite.
# Mimics enough of Claude Code's TUI behaviour to exercise the helper's
# readiness detection and keystroke-injection paths WITHOUT mocking away the
# thing we actually care about (iTerm2 scripting, `exec`, pty interaction).
#
# Contract this fake honours:
#   - `fake-claude --version`  → prints version string containing "Claude Code"
#   - bare `fake-claude`       → splash → delay → ❯ glyph → read one line → echo it
#   - `fake-claude --resume X` → same as bare plus a "resumed session" banner
#
# The fake writes what it received into $CL_FAKE_CLAUDE_OUTPUT so the test
# can assert an exact byte-for-byte match.

set -uo pipefail

# --version handler
for arg in "$@"; do
  case "$arg" in
    --version) printf '2.1.96 (Claude Code) [fake-claude test fixture]\n'; exit 0;;
  esac
done

# Parse --resume UUID (best-effort; we don't enforce format here)
resume_uuid=""
while [ $# -gt 0 ]; do
  case "$1" in
    --resume) shift; resume_uuid=${1:-};;
  esac
  shift
done

# Where to write the delivered message (the e2e test reads this to verify)
OUT=${CL_FAKE_CLAUDE_OUTPUT:-/tmp/fake-claude-received.txt}
: > "$OUT"

# Splash screen — takes a moment to render so the helper's stable-hash detector
# will see at least one stable-hash tick BEFORE the ❯ glyph appears. This
# reproduces the real Claude Code timing (~9s) and exercises the
# "stable_no_prompt keep_polling" codepath.
printf '\n'
printf ' ▐▛███▜▌   fake-claude v2.1.96 test fixture\n'
printf '▝▜█████▛▘  Opus 4.6 (1M context)\n'
printf '  ▘▘ ▝▝    [not a real Claude Code]\n'
printf '\n'

if [ -n "$resume_uuid" ]; then
  printf '  [resumed session %s]\n' "$resume_uuid"
  printf '  previous turn: fake replay\n'
  printf '  previous response: ok\n'
  printf '\n'
fi

# Flush stdout and wait long enough that the helper's stable-hash detector
# fires AT LEAST ONCE against the splash-without-prompt state before we render
# the ❯ glyph. Helper cadence is ~1.3s per poll with 3 stable ticks required,
# so 4 seconds guarantees we exercise the "splash stable, no glyph yet, keep
# polling" path.
sleep 4

# Render the prompt glyph. This is what the helper's readiness detector is
# waiting for.
printf -- '─────────────────────────────────────────────────\n'
printf '❯ \n'
printf -- '─────────────────────────────────────────────────\n'

# Block reading one line from stdin. iTerm2's `write text ... newline YES`
# delivers the bytes into the pty's input buffer, where `read -r` picks them
# up exactly as if a human had typed them.
#
# We use `read -r` because that's the most straightforward bash primitive for
# "wait for one newline-terminated line". It's a fair proxy for what the real
# Claude Code TUI does (which also waits for Enter-terminated lines via
# readline). If `write text` delivers to stdin, `read -r` sees it.
#
# The Ctrl+U that the helper sends before the real message would clear a
# readline input buffer, but for `read -r` in plain bash without readline mode
# enabled, Ctrl+U is just a 0x15 byte prepended to the line. We strip it
# before writing to the marker file.
if IFS= read -r received_line; then
  # Strip a leading 0x15 (NAK, Ctrl+U) if present — this is the helper's
  # defense-in-depth pre-clear and it's harmless here.
  received_line=${received_line#$'\025'}
  printf '%s\n' "$received_line" > "$OUT"
  printf '\n⏺ fake-claude received: %s\n' "$received_line"
else
  printf 'fake-claude: stdin closed without input\n' > "$OUT"
fi

# Brief pause so the helper's post-send observation window catches the
# confirmation text before we exit.
sleep 1

exit 0
