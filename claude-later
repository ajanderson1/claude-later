#!/bin/bash
# claude-later — schedule a Claude Code message into an iTerm2 pane.
#
# See claude-later --help for usage.
# See docs/brainstorms/claude-later-requirements.md and
# docs/plans/2026-04-07-001-feat-claude-later-snippet-plan.md for the full design.
# See claude-later/spikes/SPIKE.md for the empirical findings that shaped the implementation.

set -uo pipefail

CL_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
. "$CL_DIR/lib/util.sh"
. "$CL_DIR/lib/time.sh"
. "$CL_DIR/lib/state.sh"
. "$CL_DIR/lib/osa.sh"
CL_PF_AUTOREGISTER=1 . "$CL_DIR/lib/preflights.sh"
unset CL_PF_AUTOREGISTER

CL_VERSION="0.2.1"

# Parsed args
ARG_AT=""
ARG_IN=""
ARG_CLAUDE_ARGS=""            # Raw whitespace-separated passthrough string
ARG_DRY_RUN=0
ARG_NO_CAFFEINATE=0
ARG_ALLOW_BATTERY=0
ARG_LOG_SNAPSHOTS=0
ARG_SKIP_MCP_CHECK=0
ARG_MESSAGE=""

# Populated during pf_4_claude_args validation. Array of sub-arg tokens that
# will be exec'd verbatim into claude at fire time:
#   claude "${CL_CLAUDE_ARGS_ARR[@]}"
CL_CLAUDE_ARGS_ARR=()

# If --resume-name NAME was used inside --claude-args, this records the
# name→UUID resolution for the banner. Format: "NAME -> UUID". Empty if
# --resume-name was not used.
CL_RESUME_NAME_RESOLUTION=""

# Captured during pre-flight
CL_CLAUDE_PATH=""
CL_CLAUDE_VERSION=""
CL_ITERM_VERSION=""
CL_TARGET_EPOCH=0
CL_ARMED_AT_EPOCH=0
CL_PANE_ID=""
CL_STATE_PATH=""
CL_ACTIVE_PTR=""
CL_LOG_PATH=""
CL_HELPER_PID=""
CL_LAST_SIGNAL=""

usage() {
  cat <<'EOF'
claude-later — schedule a Claude Code message into an iTerm2 pane

USAGE
  claude-later --at TIME    [options] "message"
  claude-later --in DURATION [options] "message"

REQUIRED (exactly one)
  --at TIME       Absolute time. Accepts:
                    HH:MM                   (today if future, else tomorrow)
                    HH:MM:SS
                    YYYY-MM-DD HH:MM
                    YYYY-MM-DD HH:MM:SS
  --in DURATION   Relative time. Accepts: 30s, 5m, 4h, 2h30m, 1d12h, etc.

OPTIONS
  --claude-args "..."   Transparent passthrough of arguments to the claude
                        binary at fire time. Whitespace-separated; no quoting
                        inside. Validated against an allowlist at arm time.
                        Example: --claude-args "--teammate-mode tmux --model opus"
                        Example: --claude-args "--resume 7f3a..." (rate-limit recovery)
  --dry-run             Run all pre-flight checks (including the visible probe)
                        and print the ARMED banner, then exit without scheduling.
  --no-caffeinate       Skip the auto-re-exec under `caffeinate -dimsu`.
  --allow-battery       Override the on-battery abort.
  --log-pane-snapshots  Capture full pane content snapshots into the log file.
  --skip-mcp-check      Bypass the MCP auth-pending pre-flight.
  --help                Show this message.
  --version             Print version and exit.

CLAUDE-ARGS ALLOWLIST
  Only these sub-flags may appear inside --claude-args. Passing anything
  outside the allowlist (or inside the blocklist) is rejected at arm time.
  Allowlist:
    --resume / -r, --resume-name, --continue / -c, --model,
    --teammate-mode, --agent, --effort, --permission-mode, --name / -n,
    --append-system-prompt, --system-prompt, --fork-session, --add-dir,
    --mcp-config, --settings
  Blocklist (always rejected with explicit reason):
    -p / --print         (headless, defeats claude-later)
    -h / --help          (exits immediately)
    -v / --version       (exits immediately)
    --bare               (disables CLAUDE.md, hooks — surprising at fire time)
    --dangerously-skip-permissions, --allow-dangerously-skip-permissions
    -d / --debug, --debug-file  (TUI-breaking output)
    -w / --worktree      (changes cwd, violates first-run hygiene pre-flight)
    --session-id         (fixed session ID)

  Synthetic sub-flags (claude-later convenience, resolved at arm time):
    --resume-name NAME   Resolve NAME to a session UUID by scanning the
                         current cwd's Claude Code transcripts for a
                         /rename'd session with that exact name, then
                         rewrite to --resume <uuid> before firing. Exact
                         match only; aborts on zero matches or multiple
                         matches. Cannot be combined with --resume.

REQUIREMENTS
  - macOS only.
  - Must be run from inside an iTerm2 pane (not Terminal.app, not tmux/screen).
  - `claude` must be on PATH and have run successfully in the cwd at least once.

NOTES
  - The message is a single-line trailing positional argument.
  - State files: ~/.claude-later/state/
  - Log files:   ~/.claude-later/logs/
  - Closing the iTerm2 window cancels the job (with a tombstone + notification
    if the helper has been spawned).
EOF
}

abort() {
  printf 'claude-later: %s\n' "$1" >&2
  if [ -n "${CL_LOG_PATH:-}" ] && [ -n "${CL_LOG_PATH}" ]; then
    log_event "ABORT $1" 2>/dev/null || true
  fi
  exit "${2:-1}"
}

# ---- Argument parsing -------------------------------------------------------

parse_args() {
  if [ $# -eq 0 ]; then
    usage
    exit 0
  fi
  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) usage; exit 0;;
      --version) printf 'claude-later %s\n' "$CL_VERSION"; exit 0;;
      --at)      shift; ARG_AT=${1:-};;
      --in)      shift; ARG_IN=${1:-};;
      --claude-args) shift; ARG_CLAUDE_ARGS=${1:-};;
      --dry-run) ARG_DRY_RUN=1;;
      --no-caffeinate) ARG_NO_CAFFEINATE=1;;
      --allow-battery) ARG_ALLOW_BATTERY=1;;
      --log-pane-snapshots) ARG_LOG_SNAPSHOTS=1;;
      --skip-mcp-check) ARG_SKIP_MCP_CHECK=1;;
      --) shift; ARG_MESSAGE="$*"; return 0;;
      -*) abort "unknown flag: $1" 64;;
      *)  ARG_MESSAGE="$1";;
    esac
    shift
  done
}

# ---- Pre-flight checks ------------------------------------------------------

pf_1_platform_terminal() { cl_pf_1_platform_terminal; }

pf_2_binaries() { cl_pf_2_binaries; }

pf_3_time_parsing() {
  if [ -n "$ARG_AT" ] && [ -n "$ARG_IN" ]; then
    abort "specify exactly one of --at or --in" 64
  fi
  if [ -z "$ARG_AT" ] && [ -z "$ARG_IN" ]; then
    abort "must specify either --at or --in" 64
  fi
  if [ -n "$ARG_AT" ]; then
    CL_TARGET_EPOCH=$(parse_at "$ARG_AT") || abort "invalid --at value: $ARG_AT (DST gap, past time, or unparseable)" 64
  else
    local secs
    secs=$(parse_in "$ARG_IN") || abort "invalid --in value: $ARG_IN" 64
    CL_TARGET_EPOCH=$(( $(date +%s) + secs ))
  fi
}

# _resolve_resume_name "$name"
# Look up a Claude Code session by its /rename'd name in the current cwd's
# project transcript directory. Echoes the matched UUID on success. Aborts
# on zero matches or multiple matches.
#
# Name matching: the /rename command writes two JSONL event lines per
# rename:
#   {"type":"custom-title","customTitle":"<NAME>","sessionId":"<UUID>"}
#   {"type":"agent-name","agentName":"<NAME>","sessionId":"<UUID>"}
# We grep for either — they're written together and should stay in sync.
#
# Scope: only transcripts under ~/.claude/projects/-<cwd-slug>/ (current
# directory's project dir). A name like "TESTING_V0.2" could exist in
# multiple projects; we always resolve within the cwd the user armed from.
#
# Exact match only — no wildcards, no substring matching. The name must
# match byte-for-byte (after JSON string escaping, but since /rename names
# don't usually contain control chars this is effectively a literal match).
_resolve_resume_name() {
  local name=$1
  local cwd_slug
  cwd_slug=$(printf '%s' "$PWD" | sed -e 's|/|-|g' -e 's|_|-|g')
  local proj_dir="$HOME/.claude/projects/-${cwd_slug#-}"
  if [ ! -d "$proj_dir" ]; then
    abort "--claude-args: --resume-name lookup failed — no project directory at $proj_dir (claude has never run in this cwd)" 1
  fi

  # Build the two match needles. JSON strings embed the name exactly as
  # typed by the user; we already rejected control chars, quotes, and
  # newlines in the global sanitation rail, so the name is safe to
  # interpolate literally into a grep pattern.
  #
  # Escape grep regex metachars in the name so e.g. "TESTING_V0.2" matches
  # literally (the `.` is the only character in that example that could
  # cause a false match, but belt and braces).
  local name_escaped
  name_escaped=$(printf '%s' "$name" | sed -e 's/[][\.*+?^$(){}|/]/\\&/g')
  local needle1="\"customTitle\":\"${name_escaped}\""
  local needle2="\"agentName\":\"${name_escaped}\""

  # Find transcripts containing either needle. Each match gives a filename;
  # strip .jsonl to get the UUID.
  local matches
  matches=$(grep -l -e "$needle1" -e "$needle2" "$proj_dir"/*.jsonl 2>/dev/null)

  if [ -z "$matches" ]; then
    abort "--claude-args: no session named '$name' found in $proj_dir (use 'claude --resume' in that directory to see the full session list, or verify the name via /rename inside a session)" 1
  fi

  # Count matches and extract UUIDs. matches is newline-separated.
  local match_count uuids
  match_count=$(printf '%s\n' "$matches" | wc -l | tr -d ' ')
  uuids=$(printf '%s\n' "$matches" | while read -r path; do
    basename "$path" .jsonl
  done | sort -u)
  local uuid_count
  uuid_count=$(printf '%s\n' "$uuids" | wc -l | tr -d ' ')

  if [ "$uuid_count" -gt 1 ]; then
    local list
    list=$(printf '%s\n' "$uuids" | tr '\n' ',' | sed 's/,$//')
    abort "--claude-args: multiple sessions named '$name' in $proj_dir — disambiguate by passing --resume <uuid> directly. Matching UUIDs: $list" 1
  fi

  printf '%s\n' "$uuids"
}

# pf_4_claude_args — validate --claude-args passthrough string.
#
# Enforces all three of our safety rails:
#   1. No multi-line input, no non-printable characters, no shell quote
#      characters (single or double). These could allow argument smuggling
#      into the exec'd claude process.
#   2. Allowlist: every sub-flag must be in CL_CLAUDE_ARG_ALLOW.
#   3. Blocklist: every sub-flag must NOT be in CL_CLAUDE_ARG_BLOCK.
#      (The blocklist exists so we can give a specific, actionable error
#      reason for flags that are obviously wrong — not just "not in the
#      allowlist". E.g. `-p` gets "headless mode is unsupported" instead of
#      "unknown flag".)
#
# For `--resume VALUE` specifically, additionally validate VALUE against the
# UUID regex and check the transcript file exists. This is the one exception
# to pure passthrough — resume is our headline workflow, and catching a
# typo'd UUID at arm time (rather than a tui_not_ready tombstone at fire
# time) is worth the slight abstraction leak. See ROADMAP / CHANGELOG.
#
# On success, populates the CL_CLAUDE_ARGS_ARR global array with the
# validated tokens. On failure, aborts with a specific error message.
pf_4_claude_args() {
  CL_CLAUDE_ARGS_ARR=()
  if [ -z "$ARG_CLAUDE_ARGS" ]; then return 0; fi

  # Rail 1: input sanitation
  local nl_count
  nl_count=$(printf '%s' "$ARG_CLAUDE_ARGS" | awk 'END{print NR}')
  if [ "$nl_count" -gt 1 ]; then
    abort "--claude-args must be a single line (no embedded newlines)" 64
  fi
  if printf '%s' "$ARG_CLAUDE_ARGS" | LC_ALL=C grep -q '[^[:print:]]'; then
    abort "--claude-args contains non-printable characters" 64
  fi
  case "$ARG_CLAUDE_ARGS" in
    *\'*) abort "--claude-args must not contain single quotes (word-splitting is whitespace-only; quoted values are not honored)" 64 ;;
    *\"*) abort "--claude-args must not contain double quotes (word-splitting is whitespace-only; quoted values are not honored)" 64 ;;
  esac

  # Word-split into a bash array. IFS default is fine — whitespace only.
  # shellcheck disable=SC2206  # intentional word-splitting
  local tokens=($ARG_CLAUDE_ARGS)

  # Allowlist: sub-flags permitted. Each entry: the flag name (canonical or
  # short form). `takes_value` means the next token is the flag's argument
  # and should be consumed together.
  #
  # We use a pair of parallel case statements rather than associative arrays
  # because bash 3.2 (macOS system bash) doesn't have associative arrays.
  _is_allowed_flag() {
    case "$1" in
      --resume|-r) return 0 ;;
      --resume-name) return 0 ;;  # claude-later synthetic: resolves to --resume UUID at arm time
      --continue|-c) return 0 ;;
      --model) return 0 ;;
      --teammate-mode) return 0 ;;
      --agent) return 0 ;;
      --effort) return 0 ;;
      --permission-mode) return 0 ;;
      --name|-n) return 0 ;;
      --append-system-prompt) return 0 ;;
      --system-prompt) return 0 ;;
      --fork-session) return 0 ;;
      --add-dir) return 0 ;;
      --mcp-config) return 0 ;;
      --settings) return 0 ;;
      *) return 1 ;;
    esac
  }
  _flag_takes_value() {
    case "$1" in
      --continue|-c|--fork-session) return 1 ;;  # boolean, no value
      --resume|-r|--resume-name|--model|--teammate-mode|--agent|--effort|\
      --permission-mode|--name|-n|--append-system-prompt|--system-prompt|\
      --add-dir|--mcp-config|--settings) return 0 ;;
      *) return 1 ;;
    esac
  }
  _blocked_flag_reason() {
    case "$1" in
      -p|--print) printf 'headless mode defeats the whole point of claude-later' ;;
      -h|--help) printf '--help exits before any TUI is drawn' ;;
      -v|--version) printf '--version exits before any TUI is drawn' ;;
      --bare) printf 'skips CLAUDE.md, hooks, plugins — surprising behaviour at fire time' ;;
      --dangerously-skip-permissions|--allow-dangerously-skip-permissions)
        printf 'security-sensitive; must be explicit at arm time, not via passthrough' ;;
      -d|--debug|--debug-file) printf 'debug output breaks TUI rendering' ;;
      -w|--worktree) printf 'creates a new worktree, changes cwd at fire time and violates the first-run hygiene pre-flight' ;;
      --session-id) printf 'fixed session IDs conflict with fresh-session assumptions' ;;
      *) printf '' ;;
    esac
  }

  # Upfront conflict check for resume-family flags. We do this BEFORE the
  # main state machine loop so we can fail fast on conflict without
  # triggering the (potentially slow) --resume-name resolver.
  #
  # Two resume-family flags are handled specially:
  #   --resume UUID       — passed through verbatim, UUID validated + transcript checked
  #   --resume-name NAME  — synthetic; resolved to a UUID at arm time, then REWRITTEN
  #                         to `--resume <resolved-uuid>` in the output array. The
  #                         synthetic flag never reaches the claude exec.
  # Using BOTH in the same --claude-args is an error (they target the same thing).
  local _tc_resume=0
  local _tc_resume_name=0
  local _j
  for (( _j=0; _j<${#tokens[@]}; _j++ )); do
    case "${tokens[$_j]}" in
      --resume|-r) _tc_resume=$((_tc_resume + 1)) ;;
      --resume-name) _tc_resume_name=$((_tc_resume_name + 1)) ;;
    esac
  done
  if [ "$_tc_resume" -gt 0 ] && [ "$_tc_resume_name" -gt 0 ]; then
    abort "--claude-args: cannot use both --resume-name and --resume in the same invocation" 64
  fi
  if [ "$_tc_resume_name" -gt 1 ]; then
    abort "--claude-args: --resume-name may only appear once" 64
  fi

  local saw_resume=0
  local saw_resume_name=0
  local i=0
  local n=${#tokens[@]}
  while [ "$i" -lt "$n" ]; do
    local tok=${tokens[$i]}
    case "$tok" in
      -*)
        # Check blocklist FIRST — blocked flags give a more specific error
        # than "not in allowlist".
        local reason
        reason=$(_blocked_flag_reason "$tok")
        if [ -n "$reason" ]; then
          abort "--claude-args: blocked sub-flag '$tok': $reason" 64
        fi
        # Check allowlist
        if ! _is_allowed_flag "$tok"; then
          abort "--claude-args: sub-flag '$tok' is not in the allowlist (see --help for the full list)" 64
        fi
        # Does it consume the next token?
        if _flag_takes_value "$tok"; then
          i=$((i + 1))
          if [ "$i" -ge "$n" ]; then
            abort "--claude-args: sub-flag '$tok' requires a value but none was provided" 64
          fi
          local val=${tokens[$i]}
          # The value token must not itself start with `-` — that would be
          # the user forgetting the value and the next flag getting
          # consumed. This IS possible for flags whose value is a flag-like
          # string (rare) but we prefer false-positives here over silent
          # mis-parsing.
          case "$val" in
            -*) abort "--claude-args: sub-flag '$tok' requires a value; got another flag-like token '$val'" 64 ;;
          esac

          # Resume family — conflict check and special handling
          if [ "$tok" = "--resume" ] || [ "$tok" = "-r" ]; then
            if [ "$saw_resume_name" -eq 1 ]; then
              abort "--claude-args: cannot use both --resume-name and --resume in the same invocation" 64
            fi
            saw_resume=1
            # Validate UUID regex + check transcript
            if ! [[ "$val" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
              abort "--claude-args: --resume value must be a UUID (got '$val')" 64
            fi
            local cwd_slug
            cwd_slug=$(printf '%s' "$PWD" | sed -e 's|/|-|g' -e 's|_|-|g')
            local transcript="$HOME/.claude/projects/-${cwd_slug#-}/${val}.jsonl"
            if [ ! -r "$transcript" ]; then
              printf 'claude-later: warning: --resume transcript not found at %s (will try anyway)\n' "$transcript" >&2
            fi
            CL_CLAUDE_ARGS_ARR+=("$tok" "$val")
          elif [ "$tok" = "--resume-name" ]; then
            if [ "$saw_resume" -eq 1 ]; then
              abort "--claude-args: cannot use both --resume-name and --resume in the same invocation" 64
            fi
            if [ "$saw_resume_name" -eq 1 ]; then
              abort "--claude-args: --resume-name may only appear once" 64
            fi
            saw_resume_name=1
            # Resolve the name to a UUID. _resolve_resume_name aborts on
            # zero matches / multi-match; on success it echoes the UUID.
            local resolved_uuid
            resolved_uuid=$(_resolve_resume_name "$val") || exit 1
            # Record the resolution for the banner
            CL_RESUME_NAME_RESOLUTION="$val -> $resolved_uuid"
            # Rewrite: the synthetic --resume-name becomes a real --resume UUID
            # in the output array that gets exec'd into claude.
            CL_CLAUDE_ARGS_ARR+=("--resume" "$resolved_uuid")
          else
            # Normal pass-through (non-resume-family flag with value)
            CL_CLAUDE_ARGS_ARR+=("$tok" "$val")
          fi
        else
          # Flag with no value (boolean flag)
          CL_CLAUDE_ARGS_ARR+=("$tok")
        fi
        ;;
      *)
        abort "--claude-args: unexpected non-flag token '$tok' (all tokens must be flags or flag values)" 64
        ;;
    esac
    i=$((i + 1))
  done
}

pf_5_message_content() {
  if [ -z "$ARG_MESSAGE" ]; then
    abort "message is required (trailing positional argument)" 64
  fi
  # Reject embedded newlines (single-line only). Use awk for portability across
  # bash 3.2 quirks with $'\n' inside grep patterns.
  local nl_count
  nl_count=$(printf '%s' "$ARG_MESSAGE" | awk 'END{print NR}')
  if [ "$nl_count" -gt 1 ]; then
    abort "message must be a single line (no embedded newlines)" 64
  fi
  # Reject other control characters (not newline since we already checked above,
  # but still block tabs, escape, NUL, etc. — printable + space only).
  # Pipe-into-grep is safe here because $ARG_MESSAGE is bounded to a single
  # line (the multi-line check above guarantees it) — well under pipe buffer
  # size, so the SIGPIPE-vs-pipefail bug class can't trigger.
  if printf '%s' "$ARG_MESSAGE" | LC_ALL=C grep -q '[^[:print:]]'; then
    abort "message contains non-printable characters" 64
  fi
}

pf_6_silent_probe_secure_input() {
  # Resolve $ITERM_SESSION_ID via the scripting dictionary as a read-only check
  local uuid="${ITERM_SESSION_ID#*:}"
  if ! osa_session_alive "$uuid"; then
    local hint
    hint=$(_osa_classify_error "$(osa_last_error)")
    abort "iTerm2 scripting cannot resolve current session id (UUID=$uuid): $hint" 1
  fi
  # Secure Input check
  if sec_input_engaged; then
    abort "Secure Input is currently engaged (1Password unlock, lock screen, etc.). Wait for it to clear and try again." 1
  fi
}

pf_7_visible_probe() {
  # Intentionally removed: the visible probe wrote ": claude-later preflight ok"
  # + newline into the pane. zsh ran it as a no-op, but the bytes lingered in
  # the pty line-discipline buffer and were read as initial input by `claude`
  # after `exec claude`, appearing as a prefix on the helper's typed message.
  # pf_6's silent probe (osa_session_alive) already proves we can target this
  # pane via iTerm2 scripting. The helper also sends Ctrl+U before typing as a
  # defense-in-depth input-buffer clear.
  return 0
}

pf_8_power_sleep() {
  # Detect AC power
  local power
  power=$(pmset -g ps 2>/dev/null | head -1)
  # Case-glob instead of pipe-into-grep — see SIGPIPE-vs-pipefail bug class.
  case "$power" in
    *"Battery Power"*|*"battery power"*)
      if [ "$ARG_ALLOW_BATTERY" -eq 0 ]; then
        abort "on battery power. Plug in, or pass --allow-battery to override." 1
      fi
      printf 'claude-later: warning: on battery and --allow-battery is set; the Mac may sleep.\n' >&2
      ;;
  esac
}

pf_9_state_file() {
  state_dir_init || abort "cannot initialize ~/.claude-later/" 1
  CL_ARMED_AT_EPOCH=$(date +%s)
  CL_STATE_PATH=$(state_path_for "$ITERM_SESSION_ID" "$CL_ARMED_AT_EPOCH")
  CL_ACTIVE_PTR=$(state_active_pointer_for "$ITERM_SESSION_ID")
  local stale
  stale=$(state_check_stale "$ITERM_SESSION_ID")
  case "$stale" in
    no_active|stale)
      : # safe to arm
      ;;
    live*)
      abort "another claude-later is already armed in this pane: $stale" 1
      ;;
  esac
}

pf_10_logs() {
  CL_LOG_PATH="$CL_LOGS_ROOT/$(date +%Y-%m-%dT%H-%M-%S).log"
  log_init "$CL_LOG_PATH" || abort "cannot open log file at $CL_LOG_PATH" 1
  log_event "armed cwd=$PWD pane=$ITERM_SESSION_ID claude=$CL_CLAUDE_VERSION iterm=$CL_ITERM_VERSION target=$CL_TARGET_EPOCH"
}

pf_12_first_run_hygiene() {
  local cwd_slug
  cwd_slug=$(printf '%s' "$PWD" | sed -e 's|/|-|g' -e 's|_|-|g')
  local proj_dir="$HOME/.claude/projects/-${cwd_slug#-}"
  if [ ! -d "$proj_dir" ]; then
    abort "first-run hygiene: \`claude\` has not run in this directory yet. Run \`claude\` once interactively first to clear any trust-folder/setup prompts. (looked for: $proj_dir)" 1
  fi

  # MCP auth check — see SPIKE.md spike #8
  if [ "$ARG_SKIP_MCP_CHECK" -eq 1 ]; then
    return 0
  fi
  local mcp_cache="$HOME/.claude/mcp-needs-auth-cache.json"
  if [ -s "$mcp_cache" ]; then
    local needs
    needs=$(jq 'length' "$mcp_cache" 2>/dev/null || echo "0")
    if [ "$needs" != "0" ] && [ "$needs" != "" ]; then
      local servers
      servers=$(jq -r 'keys | join(", ")' "$mcp_cache" 2>/dev/null)
      abort "MCP servers need interactive auth: $servers. Run \`claude\` once interactively to complete authentication, then retry." 1
    fi
  fi
}

# ---- ARMED banner -----------------------------------------------------------

print_armed_banner() {
  local now
  now=$(date +%s)
  local delta=$((CL_TARGET_EPOCH - now))
  printf '\n'
  printf '\033[32m✓ claude-later ARMED\033[0m\n'
  printf '  Fire time : %s\n' "$(wall_clock_for_epoch "$CL_TARGET_EPOCH")"
  printf '              %s from now\n' "$(delta_human "$delta")"
  printf '  Pane      : %s (UUID %s)\n' "$CL_PANE_ID" "${ITERM_SESSION_ID#*:}"
  printf '  iTerm2    : %s\n' "$CL_ITERM_VERSION"
  printf '  claude    : %s\n' "$CL_CLAUDE_VERSION"
  if [ ${#CL_CLAUDE_ARGS_ARR[@]} -gt 0 ]; then
    printf '  Invocation: claude'
    local arg
    for arg in "${CL_CLAUDE_ARGS_ARR[@]}"; do
      printf ' %q' "$arg"
    done
    printf '\n'
    if [ -n "$CL_RESUME_NAME_RESOLUTION" ]; then
      printf '              (resolved --resume-name %s)\n' "$CL_RESUME_NAME_RESOLUTION"
    fi
  else
    printf '  Invocation: claude (no passthrough args)\n'
  fi
  printf '  Message   : %q (%d chars)\n' "$ARG_MESSAGE" "${#ARG_MESSAGE}"
  printf '  PID       : %d\n' "$$"
  printf '  Log       : %s\n' "$CL_LOG_PATH"
  printf '  State     : %s\n' "$CL_STATE_PATH"
  if [ "$ARG_NO_CAFFEINATE" -eq 0 ]; then
    printf '  Caffeinate: active\n'
  else
    printf '  Caffeinate: DISABLED (--no-caffeinate)\n'
  fi
  printf '\n'
  printf '  \033[33mDO NOT close this iTerm2 window. Closing it cancels the job.\033[0m\n'
  printf '\n'
}

# ---- Signal traps -----------------------------------------------------------

# Pre-T-5s trap: script owns the notification.
on_signal_pre() {
  local sig=$1
  CL_LAST_SIGNAL=$sig
  log_event "signal received pre-T-5s sig=$sig"
  state_mark "$CL_STATE_PATH" "killed" "signal=$sig" 2>/dev/null || true
  state_active_clear "$CL_ACTIVE_PTR" 2>/dev/null || true
  notify "claude-later: killed" "Script killed by SIG$sig before fire time"
  exit 1
}

# Post-T-5s trap: helper owns the notification, we just signal it.
on_signal_post() {
  local sig=$1
  CL_LAST_SIGNAL=$sig
  log_event "signal received post-T-5s sig=$sig helper_pid=$CL_HELPER_PID"
  state_mark "$CL_STATE_PATH" "killed" "signal=$sig" 2>/dev/null || true
  state_active_clear "$CL_ACTIVE_PTR" 2>/dev/null || true
  if [ -n "$CL_HELPER_PID" ]; then
    kill -TERM "$CL_HELPER_PID" 2>/dev/null || true
  fi
  exit 1
}

install_pre_traps() {
  trap 'on_signal_pre HUP' HUP
  trap 'on_signal_pre INT' INT
  trap 'on_signal_pre TERM' TERM
}

install_post_traps() {
  trap 'on_signal_post HUP' HUP
  trap 'on_signal_post INT' INT
  trap 'on_signal_post TERM' TERM
}

# ---- Main pre-flight runner -------------------------------------------------

run_preflight() {
  pf_1_platform_terminal
  pf_2_binaries
  pf_3_time_parsing
  pf_4_claude_args
  pf_5_message_content
  pf_12_first_run_hygiene
  pf_8_power_sleep
  pf_9_state_file
  pf_10_logs

  # Build a JSON array of the validated claude-args tokens for the state
  # file. Pass through jq -R -s -c 'split("\u0000")[:-1]' with NUL separator
  # to handle any whitespace-containing tokens correctly. (Since we reject
  # quotes, current tokens can't contain whitespace, but this is future-proof.)
  local claude_args_json
  if [ ${#CL_CLAUDE_ARGS_ARR[@]} -eq 0 ]; then
    claude_args_json='[]'
  else
    claude_args_json=$(printf '%s\0' "${CL_CLAUDE_ARGS_ARR[@]}" \
      | jq -R -s -c 'split("\u0000")[:-1]') || abort "cannot encode claude_args as JSON" 1
  fi

  # State file written before probes so we have a place to log to.
  state_write "$CL_STATE_PATH" \
    "$ITERM_SESSION_ID" \
    "$CL_ITERM_VERSION" \
    "$CL_CLAUDE_VERSION" \
    "$CL_PANE_ID" \
    "$$" \
    "$CL_TARGET_EPOCH" \
    "$CL_ARMED_AT_EPOCH" \
    "$claude_args_json" \
    "$ARG_MESSAGE" \
    "$CL_LOG_PATH" || abort "cannot write state file" 1
  state_active_set "$CL_ACTIVE_PTR" "$CL_STATE_PATH"

  pf_6_silent_probe_secure_input
  pf_7_visible_probe
}

# ---- Sleep loop and fire ----------------------------------------------------

sleep_until_fire() {
  install_pre_traps
  log_event "sleep loop start target=$CL_TARGET_EPOCH"
  while :; do
    local now
    now=$(date +%s)
    local remaining=$((CL_TARGET_EPOCH - now))
    if [ "$remaining" -le 5 ]; then
      log_event "sleep loop reached T-5s window"
      break
    fi
    if polling_missed_window "$now" "$CL_TARGET_EPOCH" 60; then
      log_event "missed window pre-helper-spawn"
      state_mark "$CL_STATE_PATH" "missed_window" "asleep through fire window"
      state_active_clear "$CL_ACTIVE_PTR"
      notify "claude-later: missed_window" "System was asleep through the fire window"
      exit 1
    fi
    local nap=$((remaining - 5))
    if [ "$nap" -gt 30 ]; then nap=30; fi
    sleep "$nap"
  done
}

spawn_helper_and_exec() {
  log_event "T-5s reached, spawning helper"
  # Spawn the detached helper.
  nohup "$CL_DIR/claude-later-helper" "$CL_STATE_PATH" </dev/null >>"$CL_LOG_PATH" 2>&1 &
  CL_HELPER_PID=$!
  disown
  log_event "helper spawned pid=$CL_HELPER_PID"

  # Switch trap behavior: post-T-5s, the helper owns notifications.
  install_post_traps

  # Wait until T-0, polling for missed-window.
  while :; do
    local now
    now=$(date +%s)
    local remaining=$((CL_TARGET_EPOCH - now))
    if [ "$remaining" -le 0 ]; then break; fi
    if polling_missed_window "$now" "$CL_TARGET_EPOCH" 60; then
      log_event "missed window post-helper-spawn"
      state_mark "$CL_STATE_PATH" "missed_window" "asleep through fire window after helper spawn"
      state_active_clear "$CL_ACTIVE_PTR"
      kill -TERM "$CL_HELPER_PID" 2>/dev/null || true
      exit 1
    fi
    sleep 1
  done

  # Final pre-fire checks at T-0.
  log_event "T-0 final pre-fire checks"
  local current_iterm
  current_iterm=$(osa_iterm_version)
  if [ "$current_iterm" != "$CL_ITERM_VERSION" ]; then
    log_event "iterm version changed at T-0"
    state_mark "$CL_STATE_PATH" "iterm_version_changed" "$CL_ITERM_VERSION -> $current_iterm"
    kill -TERM "$CL_HELPER_PID" 2>/dev/null || true
    exit 1
  fi
  local current_claude
  current_claude=$(claude --version 2>/dev/null)
  if [ "$current_claude" != "$CL_CLAUDE_VERSION" ]; then
    log_event "claude version changed at T-0"
    state_mark "$CL_STATE_PATH" "claude_version_changed" "$CL_CLAUDE_VERSION -> $current_claude"
    kill -TERM "$CL_HELPER_PID" 2>/dev/null || true
    exit 1
  fi
  if sec_input_engaged; then
    log_event "Secure Input engaged at T-0"
    state_mark "$CL_STATE_PATH" "secure_input_engaged" "engaged at T-0"
    kill -TERM "$CL_HELPER_PID" 2>/dev/null || true
    exit 1
  fi
  local uuid="${ITERM_SESSION_ID#*:}"
  if ! osa_session_alive "$uuid"; then
    log_event "session died at T-0"
    state_mark "$CL_STATE_PATH" "session_died_pre_exec" "iterm session no longer resolves at T-0"
    kill -TERM "$CL_HELPER_PID" 2>/dev/null || true
    exit 1
  fi

  log_event "T-0 checks passed, exec'ing claude"
  state_mark "$CL_STATE_PATH" "fired"

  # exec replaces our process with claude. The helper is detached and survives.
  # CL_CLAUDE_ARGS_ARR is the validated passthrough array from pf_4.
  if [ ${#CL_CLAUDE_ARGS_ARR[@]} -gt 0 ]; then
    exec "$CL_CLAUDE_PATH" "${CL_CLAUDE_ARGS_ARR[@]}"
  else
    exec "$CL_CLAUDE_PATH"
  fi
}

# ---- Caffeinate re-exec -----------------------------------------------------

reexec_under_caffeinate() {
  if [ "$ARG_NO_CAFFEINATE" -eq 1 ]; then return 0; fi
  if [ "${CL_UNDER_CAFFEINATE:-0}" = "1" ]; then return 0; fi
  export CL_UNDER_CAFFEINATE=1
  exec caffeinate -dimsu "$0" "$@"
}

# ---- Main -------------------------------------------------------------------

main() {
  parse_args "$@"
  # Re-exec under caffeinate BEFORE pre-flights so state/.active is written
  # exactly once (otherwise pf_9 sees its own prior-pass state as "live").
  # Dry-runs skip caffeinate entirely.
  if [ "$ARG_DRY_RUN" -ne 1 ]; then
    reexec_under_caffeinate "$@"
  fi
  run_preflight
  print_armed_banner

  if [ "$ARG_DRY_RUN" -eq 1 ]; then
    log_event "dry-run complete, exiting without scheduling"
    state_active_clear "$CL_ACTIVE_PTR"
    exit 0
  fi

  sleep_until_fire
  spawn_helper_and_exec
}

main "$@"
